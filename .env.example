# ========================
# layerframe-ops 環境變數
# 複製此檔案為 .env 後填入實際值
# ========================

# --- 資料庫 ---
DB_HOST=db                         # Docker Compose 中用 service 名稱
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_secure_password_here  # 請改成安全密碼
DB_NAME=layerframe

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT 認證 ---
# RS256 金鑰（Base64 編碼）
# 產生方式：openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# 編碼方式：cat private.pem | base64 -w0
JWT_PRIVATE_KEY=                   # Base64 encoded private key
JWT_PUBLIC_KEY=                    # Base64 encoded public key
JWT_ACCESS_EXPIRY=15m              # Access Token 有效期
JWT_REFRESH_EXPIRY=7d              # Refresh Token 有效期

# --- 加密 ---
ENCRYPTION_KEY=                    # 32 bytes hex，用於 AES-256-GCM 加密金流設定
                                   # 產生方式：openssl rand -hex 32

# --- 金流（依租戶配置，此為預設/測試用） ---
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=
LINEPAY_CHANNEL_ID=
LINEPAY_CHANNEL_SECRET=

# --- 應用 ---
APP_PORT=3000
APP_ENV=development                # development | staging | production
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# --- Supabase（僅 PostgreSQL 託管，正式環境用） ---
SUPABASE_URL=
SUPABASE_DB_URL=
